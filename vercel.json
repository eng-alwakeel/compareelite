{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/blog/article", "destination": "/api/article-meta" },
    { "source": "/dashboard/login", "destination": "/dashboard/login.html" },
    { "source": "/product/:slug*", "destination": "/api/gone" },
    { "source": "/brand/:slug", "destination": "/pages/brand/article.html" },
    { "source": "/brands", "destination": "/pages/brands/index.html" },
    { "source": "/brands/:brand", "destination": "/pages/brands/brand.html" }
  ],
  "headers": [
    {
      "source": "/(.*).txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    }
  ]
}
