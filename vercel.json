{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/blog/article",
      "has": [
        { "type": "query", "key": "slug", "value": "(?<slug>[a-z0-9-]+)" }
      ],
      "destination": "/blog/article/:slug",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/blog/article", "destination": "/blog/article.html" },
    { "source": "/dashboard/login", "destination": "/dashboard/login.html" },
    { "source": "/product/:slug*", "destination": "/api/gone" }
  ],
  "headers": [
    {
      "source": "/(.*).txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    }
  ]
}
