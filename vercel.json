{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/blog/article", "destination": "/blog/article.html" },
    { "source": "/dashboard/login", "destination": "/dashboard/login.html" },
    { "source": "/product/:slug*", "destination": "/api/gone" }
  ],
  "headers": [
    {
      "source": "/(.*).txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    }
  ]
}
